{
  "name": "SodaDiner",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "test": "npm test -w server"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "prettier": "3.8.1"
  }
}
