{
	"name": "soda-diner-server",
	"version": "4.2.0",
	"type": "module",
	"main": "server.ts",
	"scripts": {
		"dev": "node --watch --env-file=.env server.ts",
		"start": "node --env-file=.env server.ts",
		"test": "mocha -R list",
		"model": "mocha _test_/model.test.js",
		"controller": "mocha _test_/controller.test.js",
		"route": "mocha _test_/route.test.js",
		"crud": "mongorestore --uri mongodb://localhost:27017/SodaDinerTest --drop dumpedDB/tests && ENV=test mocha _test_/cruds",
		"allTest": "mongorestore --uri mongodb://localhost:27017/SodaDinerTest --drop dumpedDB/tests && ENV=test mocha _test_ _test_/cruds",
		"clp": "node CLProc/trigger.js",
		"dumpDev": "mongodump --uri mongodb://localhost:27017/SodaDiner --out dumpedDB/developer",
		"restoreDev": "mongorestore --uri mongodb://localhost:27017/SodaDiner --drop dumpedDB/developer/SodaDiner",
		"dumpTest": "mongodump --uri mongodb://localhost:27017/SodaDinerTest --out dumpedDB/tests",
		"restoreTest": "mongorestore --uri mongodb://localhost:27017/SodaDinerTest --drop dumpedDB/tests"
	},
	"dependencies": {
		"cors": "2.8.6",
		"express": "4.22.1",
		"inquirer": "9.3.8",
		"mongoose": "8.23.0",
		"morgan": "1.10.1",
		"typescript": "5.9.3"
	},
	"devDependencies": {
		"@types/cors": "2.8.19",
		"@types/express": "5.0.6",
		"@types/morgan": "1.9.10",
		"@types/node": "24.12.0",
		"mocha": "10.8.2"
	},
	"imports": {
		"#config": "./config.js",
		"#models/*": "./models/*.model.js",
		"#controllers/*": "./controllers/*.control.js",
		"#routes/*": "./routes/*.route.js",
		"#resp": "./_test_/cruds/dummyRes.js",
		"#connect": "./monCon.js"
	}
}
